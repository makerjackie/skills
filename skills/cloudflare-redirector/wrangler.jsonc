{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-bulk-redirector",
	// 推荐通过环境变量 CLOUDFLARE_ACCOUNT_ID 提供 account_id，避免写入仓库。
	"main": "src/index.ts",
	"compatibility_date": "2026-03-11",
	"routes": [
		{
			"pattern": "docs.example.com/*",
			"zone_name": "example.com"
		}
	],
	"observability": {
		"enabled": true
	}
}
